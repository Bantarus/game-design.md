{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-design.md/schema/v0.2.0-alpha/game-design.schema.json",
  "title": "game-design.md frontmatter (v0.2.0-alpha)",
  "description": "Discriminated union over file_type. See docs/spec.md for normative semantics.",
  "type": "object",
  "required": ["spec", "spec_version", "file_type"],
  "properties": {
    "spec": { "const": "game-design.md" },
    "spec_version": { "$ref": "#/$defs/SemVer" },
    "file_type": {
      "enum": ["core", "subfile", "content-schema", "content-entity"]
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/CoreFile" },
    { "$ref": "#/$defs/Subfile" },
    { "$ref": "#/$defs/ContentSchemaFile" },
    { "$ref": "#/$defs/ContentEntityFile" }
  ],

  "$defs": {
    "SemVer": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },

    "ISODate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "Status": {
      "enum": ["draft", "prototyped", "implemented", "balanced", "shipped", "cut"]
    },

    "TokenRef": {
      "type": "string",
      "pattern": "^\\{[a-z_][a-z0-9_]*(?:\\.[a-z0-9_][a-z0-9_-]*){1,5}\\}$",
      "description": "{namespace.id...} with 2..6 dot-separated segments."
    },

    "ImplementedIn": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Workspace-relative path globs (fast-glob style)."
    },

    "ImplementationPointers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },

    "FilesMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^[^\\s].*\\.(md|yaml|yml)$"
      }
    },

    "MDAAesthetic": {
      "enum": ["sensation", "fantasy", "narrative", "challenge", "fellowship", "discovery", "expression", "submission"]
    },

    "Timescale": { "enum": ["moment", "session", "meta"] },
    "Scope":     { "enum": ["per_turn", "per_run", "permanent"] },
    "Visibility":{ "enum": ["hud", "inferred", "hidden"] },

    "PlayerExperienceGoals": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary":            { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" }, "minItems": 1 },
        "secondary":          { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" } },
        "explicit_non_goals": { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" } }
      },
      "additionalProperties": false
    },

    "Entity": {
      "type": "object",
      "required": ["type", "status"],
      "properties": {
        "type": {
          "enum": ["actor", "content_collection", "terrain", "currency", "system_object", "instance_container"],
          "description": "Entity cardinality. `actor`: a single instance (the player, a boss). `content_collection`: many templates from `data_source/*.yaml`. `instance_container` (F-008 v0.3): N owned instances each carrying per-instance runtime state — closes the gap the three-layer (actor / content_collection / scalar-resource) vocabulary couldn't express."
        },
        "properties": { "type": "object" },
        "data_source": { "type": "string" },
        "schema_ref": { "$ref": "#/$defs/TokenRef" },
        "count_target": { "type": "integer", "minimum": 0 },
        "capacity": {
          "type": "integer",
          "minimum": 0,
          "description": "F-008 v0.3: maximum simultaneous instances for `type: instance_container`. The container holds 0..capacity instances at any moment."
        },
        "holds_template_from": {
          "$ref": "#/$defs/TokenRef",
          "description": "F-008 v0.3: required for `type: instance_container`. Token ref to the `{entities.<kind>}` content_collection that defines the templates instances are drawn from. The container holds runtime instances of these templates."
        },
        "per_instance_state": {
          "type": "object",
          "description": "F-008 v0.3: required for `type: instance_container`. Sub-schema declaring the runtime-state fields each owned instance carries (durability, charges, quantity, etc.). Field values are type declarations in the same shape as content_collection.schema.properties. Validation of per-instance values against this sub-schema is the engine's responsibility at runtime."
        },
        "status": { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "allOf": [
        {
          "if":   { "properties": { "type": { "const": "content_collection" } }, "required": ["type"] },
          "then": { "required": ["data_source"] }
        },
        {
          "if":   { "properties": { "type": { "const": "instance_container" } }, "required": ["type"] },
          "then": { "required": ["capacity", "holds_template_from", "per_instance_state", "implemented_in"] }
        },
        {
          "if": {
            "not": {
              "properties": {
                "type": { "enum": ["content_collection", "instance_container"] }
              },
              "required": ["type"]
            }
          },
          "then": { "required": ["properties", "implemented_in"] }
        }
      ],
      "additionalProperties": true
    },

    "Cost": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string" },
        {
          "type": "object",
          "required": ["resource", "amount"],
          "properties": {
            "resource": { "$ref": "#/$defs/TokenRef" },
            "amount":   { }
          }
        }
      ]
    },

    "Verb": {
      "type": "object",
      "required": ["actor", "cost", "target_schema", "effects", "status", "implemented_in"],
      "properties": {
        "actor":         { "type": "string", "minLength": 1 },
        "cost":          { "$ref": "#/$defs/Cost" },
        "target_schema": { "type": "object" },
        "effects":       { "type": "array", "minItems": 1 },
        "feel":          { "$ref": "#/$defs/TokenRef" },
        "status":        { "$ref": "#/$defs/Status" },
        "implemented_in":{ "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": true
    },

    "Resource": {
      "type": "object",
      "required": ["scope", "min", "max", "visibility", "status", "implemented_in"],
      "properties": {
        "scope":            { "$ref": "#/$defs/Scope" },
        "min":              { "type": "number" },
        "max":              { "type": "number" },
        "velocity_target":  { "$ref": "#/$defs/TokenRef" },
        "visibility":       { "$ref": "#/$defs/Visibility" },
        "status":           { "$ref": "#/$defs/Status" },
        "implemented_in":   { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "StateMachine": {
      "type": "object",
      "required": ["initial", "nodes", "transitions"],
      "properties": {
        "initial":     { "type": "string", "minLength": 1 },
        "nodes":       { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/StateNode" } },
        "transitions": { "type": "array", "items": { "$ref": "#/$defs/StateTransition" } }
      },
      "additionalProperties": false
    },

    "StateNode": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id":       { "type": "string", "minLength": 1, "pattern": "^[a-z0-9_]+$" },
        "terminal": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "StateTransition": {
      "type": "object",
      "required": ["from", "event", "to"],
      "properties": {
        "from":         { "type": "string", "minLength": 1 },
        "event":        { "type": "string", "minLength": 1 },
        "to":           { "type": "string", "minLength": 1 },
        "side_effects": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "Invariant": {
      "type": "object",
      "required": ["kind", "rule", "enforcement", "severity"],
      "properties": {
        "kind":        { "enum": ["numeric_domain", "architectural_pattern", "layer_boundary", "communication", "determinism"] },
        "rule":        { "type": "string", "minLength": 1 },
        "applies_to":  { "type": "array", "items": { "$ref": "#/$defs/TokenRef" } },
        "enforcement": { "enum": ["lint", "verify", "advisory"] },
        "severity":    { "enum": ["error", "warning", "info"] }
      },
      "additionalProperties": false
    },

    "Event": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" },
        "description":    { "type": "string" }
      },
      "additionalProperties": false
    },

    "VerifyTarget": {
      "type": "object",
      "required": ["axis"],
      "properties": {
        "axis":             { "enum": ["build_health", "behavioral_alignment", "presentation_usability"] },
        "target":           { "$ref": "#/$defs/TokenRef" },
        "seed":             { "type": "integer" },
        "sessions":         { "type": "integer", "minimum": 1 },
        "expect":           { "type": "object" },
        "negative_control": { "$ref": "#/$defs/NegativeControl" }
      },
      "additionalProperties": false
    },

    "NegativeControl": {
      "description": "Spec §9.5.7. Declares one or more alternative seeds the adapter must also run; verify asserts each negative-control trajectory differs byte-for-byte from the primary.",
      "type": "object",
      "required": ["seeds", "expect"],
      "properties": {
        "seeds":  { "type": "array", "items": { "type": "integer" }, "minItems": 1 },
        "expect": { "type": "object" }
      },
      "additionalProperties": false
    },

    "TrajectorySpec": {
      "description": "Spec §9.5.5. Per-game canonical trajectory declaration. The schema body is advisory at v0.2.0-alpha and ratchets to JSON Schema validation in v0.3; trajectory equality is checked byte-for-byte against the golden fixture.",
      "type": "object",
      "required": ["unit"],
      "properties": {
        "unit":   { "type": "string", "minLength": 1 },
        "schema": { "type": "object" }
      },
      "additionalProperties": true
    },

    "VerifyResult": {
      "type": "object",
      "required": ["results", "summary"],
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["axis", "pass"],
            "properties": {
              "axis":     { "enum": ["build_health", "behavioral_alignment", "presentation_usability"] },
              "target":   { "type": "string" },
              "observed": { },
              "expected": { },
              "pass":     { "type": "boolean" },
              "notes":    { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "summary": {
          "type": "object",
          "required": ["runs", "passed", "failed", "skipped"],
          "properties": {
            "runs":    { "type": "integer", "minimum": 0 },
            "passed":  { "type": "integer", "minimum": 0 },
            "failed":  { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "Rule": {
      "type": "object",
      "required": ["given", "do", "outputs", "status", "implemented_in"],
      "properties": {
        "given": {
          "description": "Trigger condition. A rule fires because a verb is issued (`verb:`) OR because a clock advances (`driver:`). Exactly one of `verb:` or `driver:` is the firing source; the other should be absent. `state:` optionally narrows the firing precondition.",
          "type": "object",
          "anyOf": [
            { "required": ["verb"] },
            { "required": ["driver"] }
          ],
          "properties": {
            "verb":   { "$ref": "#/$defs/TokenRef" },
            "driver": { "$ref": "#/$defs/TokenRef" },
            "state":  { "$ref": "#/$defs/TokenRef" }
          },
          "additionalProperties": true
        },
        "do":             { "type": "array", "minItems": 1 },
        "outputs":        { "type": "array" },
        "target_selection": {
          "description": "D-013: how the rule picks its target. Closed vocabulary; 'none' means the rule has no target.",
          "enum": [
            "none",
            "first_alive_opposite",
            "lowest_hp_opposite",
            "highest_hp_opposite",
            "random_alive_opposite",
            "self",
            "explicit"
          ]
        },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "Loop": {
      "type": "object",
      "required": ["timescale", "duration", "sequence", "intended_dynamics", "intended_aesthetics", "status", "implemented_in"],
      "properties": {
        "timescale":           { "$ref": "#/$defs/Timescale" },
        "duration":            { "type": "string" },
        "sequence":            { "type": "array" },
        "clock": {
          "$ref": "#/$defs/TokenRef",
          "description": "F-010 / v0.3: optional reference to a {clocks.<id>} that drives this loop's iteration. When present, `sequence:` may be empty (the loop is purely clock-driven — e.g., tick-combat's tick loop). When absent, `sequence:` must be non-empty (the loop iterates through player verbs)."
        },
        "intended_dynamics":   { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "intended_aesthetics": { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" }, "minItems": 1 },
        "feel_priority":       { "enum": ["low", "medium", "high"] },
        "balance_targets":     { "type": "array", "items": { "$ref": "#/$defs/TokenRef" } },
        "status":              { "$ref": "#/$defs/Status" },
        "implemented_in":      { "$ref": "#/$defs/ImplementedIn" }
      },
      "anyOf": [
        { "properties": { "sequence": { "minItems": 1 } } },
        { "required": ["clock"] }
      ],
      "additionalProperties": false
    },

    "Distribution": {
      "type": "object",
      "required": ["type", "status", "implemented_in"],
      "properties": {
        "type":           { "enum": ["uniform", "weighted", "shuffle_bag", "gaussian", "pity_floor", "deterministic", "ordering_rule", "discrete_sum"] },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" },
        "seed":           { "type": "string" },
        "params_from":    {
          "type": "object",
          "description": "D-012: distribution parameters templated from a context-local ref (e.g. {actor.attack}). Keys match the distribution's parameter names (mean, stddev, threshold, …); values are TokenRef-shaped strings resolved at rule-evaluation time.",
          "additionalProperties": { "type": "string" }
        },
        "selection_rule": {
          "description": "D-017 / Phase 4+. For `weighted`: 'declaration_order_first_above' (the only normative value at v0.2.0-alpha). For `uniform` with threshold: 'less_than' | 'less_than_or_equal' | 'greater_than' | 'greater_than_or_equal' | 'equal'.",
          "type": "string"
        },
        "prng": {
          "$ref": "#/$defs/PrngSpec",
          "description": "D-015 / Phase 4+. Optional per-distribution PRNG override. Tree-level default lives at the subfile level."
        }
      },
      "allOf": [
        {
          "if":   { "properties": { "type": { "const": "uniform" } } },
          "then": { "required": ["range"], "properties": { "range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 } } }
        },
        {
          "if":   { "properties": { "type": { "const": "weighted" } } },
          "then": {
            "required": ["options"],
            "properties": {
              "options": {
                "type": "object",
                "minProperties": 2,
                "additionalProperties": {
                  "oneOf": [
                    { "type": "number", "minimum": 0 },
                    {
                      "type": "object",
                      "required": ["weight"],
                      "properties": {
                        "weight": { "type": "number", "minimum": 0 },
                        "value":  { }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              }
            }
          }
        },
        {
          "if":   { "properties": { "type": { "const": "shuffle_bag" } } },
          "then": { "required": ["of"], "properties": { "of": { "$ref": "#/$defs/TokenRef" }, "refill_when": { "enum": ["empty", "manual", "per_run"] } } }
        },
        {
          "if":   { "properties": { "type": { "const": "gaussian" } } },
          "then": { "required": ["mean", "stddev"], "properties": { "mean": { "type": "number" }, "stddev": { "type": "number", "exclusiveMinimum": 0 }, "clamp": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 } } }
        },
        {
          "if":   { "properties": { "type": { "const": "pity_floor" } } },
          "then": { "required": ["table", "weights"], "properties": { "table": { "type": "array" }, "weights": { "type": "array", "items": { "type": "number" } }, "pity": { "type": "object" } } }
        },
        {
          "if":   { "properties": { "type": { "const": "deterministic" } } },
          "then": { "required": ["sequence"], "properties": { "sequence": { "type": "array", "minItems": 1 } } }
        },
        {
          "if":   { "properties": { "type": { "const": "ordering_rule" } } },
          "then": {
            "required": ["over", "sort"],
            "properties": {
              "over":   { "$ref": "#/$defs/TokenRef" },
              "filter": { "type": "object", "additionalProperties": true },
              "sort": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["by", "direction"],
                  "properties": {
                    "by":        { "type": "string", "minLength": 1 },
                    "direction": { "enum": ["asc", "desc"] }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        {
          "if":   { "properties": { "type": { "const": "discrete_sum" } } },
          "then": {
            "description": "D-016 / Phase 4+. Integer-native gaussian-like distribution: sum `samples` PRNG draws each uniform integer in `range`, then add `mean` (or `params_from.mean`), then `clamp`. Zero transcendentals; bit-identical across engines that share the pinned PRNG.",
            "required": ["samples", "range"],
            "properties": {
              "samples": { "type": "integer", "minimum": 1 },
              "range":   { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
              "mean":    { "type": "integer" },
              "clamp":   { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
            }
          }
        }
      ],
      "additionalProperties": true
    },

    "PrngSpec": {
      "description": "D-015 / Phase 4+. PRNG declaration for a tree or per-distribution. Pinned algorithm + seeding contract + reference vector for self-validation.",
      "type": "object",
      "required": ["algorithm", "seeding"],
      "properties": {
        "algorithm": {
          "enum": ["xoshiro256_starstar", "chacha20", "pcg32", "pcg64"],
          "description": "Closed vocabulary at v0.2.0-alpha. Default: xoshiro256_starstar (small, bit-identical-friendly). chacha20 is the per-game override for unpredictability."
        },
        "seeding": {
          "enum": ["splitmix64", "identity"],
          "description": "How a single u64 seed maps to PRNG initial state. splitmix64 fills xoshiro's 4×u64 state; identity is the passthrough for PRNGs that accept the seed directly."
        },
        "reference_vector": {
          "type": "object",
          "required": ["canonical_seed", "outputs"],
          "properties": {
            "canonical_seed": { "type": "integer" },
            "outputs": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" }
            }
          },
          "additionalProperties": false
        },
        "uniform_int_reference_vector": {
          "description": "D-018 / Phase 4++. Reduction-layer self-validation: each entry asserts that `uniform_int_inclusive(range[0], range[1])` at `canonical_seed` produces `outputs`. At least one entry SHOULD use a non-power-of-two `range` width to catch the signed-int64 host's naive-corrected modulo (which silently equals the correct u64 modulo only when 2^64 mod w = 0).",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["canonical_seed", "range", "outputs"],
            "properties": {
              "canonical_seed": { "type": "integer" },
              "range": {
                "type": "array",
                "items": { "type": "integer" },
                "minItems": 2,
                "maxItems": 2
              },
              "outputs": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "integer" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "Clock": {
      "description": "F-010 / v0.3: first-class time-passage primitive distinct from player verbs. A clock drives one or more rules to fire on time advancement rather than on verb issuance. Two modes at v0.2.0-alpha: `continuous` (periodic, e.g., 60Hz physics) and `per_verb_delta` (advances after each player verb by an explicit delta read from the verb's properties). Closed enum; future modes (`scheduled` for wave-timers / day-night, etc.) ratchet by observed use, not anticipation.",
      "type": "object",
      "required": ["mode", "drives", "status", "implemented_in"],
      "properties": {
        "mode": {
          "enum": ["continuous", "per_verb_delta"],
          "description": "`continuous`: the clock advances on its own at a fixed rate (requires `rate:`). `per_verb_delta`: the clock advances after each player verb fires, by an amount read from a context-local source (requires `delta_source:`)."
        },
        "drives": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/TokenRef" },
          "description": "Token refs to {rules.<id>} the clock fires on each advancement."
        },
        "rate": {
          "type": "object",
          "description": "Required when mode=continuous. Declare exactly one of `hz:` (frequency) or `period_ms:` (interval).",
          "properties": {
            "hz": { "type": "number", "exclusiveMinimum": 0 },
            "period_ms": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        },
        "delta_source": {
          "type": "string",
          "description": "Required when mode=per_verb_delta. Dotted context-local path read at apply-time (per spec §3) — e.g., 'verb.time_cost.in_game_minutes' resolves to the firing verb's time_cost.in_game_minutes value. The clock advances by that delta after each verb fires."
        },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "allOf": [
        {
          "if":   { "properties": { "mode": { "const": "continuous" } }, "required": ["mode"] },
          "then": { "required": ["rate"] }
        },
        {
          "if":   { "properties": { "mode": { "const": "per_verb_delta" } }, "required": ["mode"] },
          "then": { "required": ["delta_source"] }
        }
      ],
      "additionalProperties": false
    },

    "Feel": {
      "type": "object",
      "required": ["input", "response", "context", "polish", "metaphor", "rules", "status", "implemented_in"],
      "properties": {
        "input":          { "type": "string" },
        "response":       { "type": "string" },
        "context":        { "type": "string" },
        "polish":         { "type": "string" },
        "metaphor":       { "type": "string" },
        "rules":          { "type": "string" },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "BalanceTarget": {
      "type": "object",
      "required": ["target_kind", "target", "measure", "status"],
      "properties": {
        "target_kind": { "enum": ["scalar", "range", "distribution_over_categories"] },
        "target":      { },
        "tolerance":   { },
        "measure":     { "type": "string" },
        "status":      { "$ref": "#/$defs/Status" }
      },
      "allOf": [
        {
          "if":   { "properties": { "target_kind": { "const": "scalar" } }, "required": ["target_kind"] },
          "then": {
            "required": ["tolerance"],
            "properties": {
              "tolerance": { "type": "array", "minItems": 2, "maxItems": 2 }
            }
          }
        },
        {
          "if":   { "properties": { "target_kind": { "const": "range" } }, "required": ["target_kind"] },
          "then": {
            "properties": {
              "target": {
                "oneOf": [
                  {
                    "type": "object", "required": ["between"], "additionalProperties": false,
                    "properties": {
                      "between": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
                    }
                  },
                  {
                    "type": "object", "required": ["near", "tolerance"], "additionalProperties": false,
                    "properties": {
                      "near":      { "type": "number" },
                      "tolerance": { "type": "number", "minimum": 0 }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if":   { "properties": { "target_kind": { "const": "distribution_over_categories" } }, "required": ["target_kind"] },
          "then": {
            "required": ["tolerance"],
            "properties": {
              "target":    { "type": "object", "minProperties": 1 },
              "tolerance": { "type": "object", "minProperties": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    },

    "CoreFile": {
      "type": "object",
      "required": [
        "spec", "spec_version", "file_type",
        "name", "short_pitch", "genre_tags",
        "status", "version", "last_updated",
        "target_platforms_neutral",
        "pillars", "non_goals", "player_experience_goals",
        "core_loop_ref", "files"
      ],
      "properties": {
        "spec":         { "const": "game-design.md" },
        "spec_version": { "$ref": "#/$defs/SemVer" },
        "file_type":    { "const": "core" },
        "name":         { "type": "string", "minLength": 1 },
        "short_pitch":  { "type": "string", "minLength": 1, "maxLength": 280 },
        "genre_tags":   { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "status":       { "$ref": "#/$defs/Status" },
        "version":      { "$ref": "#/$defs/SemVer" },
        "last_updated": { "$ref": "#/$defs/ISODate" },
        "target_platforms_neutral": {
          "type": "array",
          "items": { "enum": ["desktop", "handheld", "web", "console", "mobile", "mixed-reality"] },
          "minItems": 1
        },
        "pillars":      { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 5 },
        "non_goals":    { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "player_experience_goals": { "$ref": "#/$defs/PlayerExperienceGoals" },
        "core_loop_ref":{ "$ref": "#/$defs/TokenRef" },
        "files":        { "$ref": "#/$defs/FilesMap" },
        "implementation_pointers": { "$ref": "#/$defs/ImplementationPointers" },
        "verify_targets": { "type": "array", "items": { "$ref": "#/$defs/VerifyTarget" } },
        "adapters": {
          "type": "object",
          "additionalProperties": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
        }
      },
      "additionalProperties": false
    },

    "Subfile": {
      "type": "object",
      "required": ["spec", "spec_version", "file_type", "status", "last_verified"],
      "properties": {
        "spec":           { "const": "game-design.md" },
        "spec_version":   { "$ref": "#/$defs/SemVer" },
        "file_type":      { "const": "subfile" },
        "status":         { "$ref": "#/$defs/Status" },
        "last_verified":  { "$ref": "#/$defs/ISODate" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" },
        "implementation_pointers": { "$ref": "#/$defs/ImplementationPointers" },

        "entities": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Entity" } },
        "verbs":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/Verb" } },
        "resources":{ "type": "object", "additionalProperties": { "$ref": "#/$defs/Resource" } },
        "states":   { "type": "object", "additionalProperties": { "$ref": "#/$defs/StateMachine" } },
        "rules":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/Rule" } },
        "loops":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/Loop" } },
        "distributions": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Distribution" } },
        "feel":     { "type": "object", "additionalProperties": { "$ref": "#/$defs/Feel" } },
        "balance_targets": { "type": "object", "additionalProperties": { "$ref": "#/$defs/BalanceTarget" } },
        "invariants":      { "type": "object", "additionalProperties": { "$ref": "#/$defs/Invariant" } },
        "events":          { "type": "object", "additionalProperties": { "$ref": "#/$defs/Event" } },
        "clocks":          { "type": "object", "additionalProperties": { "$ref": "#/$defs/Clock" } },

        "verify_targets": { "type": "array", "items": { "$ref": "#/$defs/VerifyTarget" } },
        "adapters": {
          "type": "object",
          "additionalProperties": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
        },
        "trajectory":  { "$ref": "#/$defs/TrajectorySpec" },
        "prng":        { "$ref": "#/$defs/PrngSpec" },

        "pillars":     { "type": "array", "items": { "type": "string" } },
        "non_goals":   { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },

    "ContentSchemaFile": {
      "type": "object",
      "required": ["spec", "spec_version", "file_type", "status", "last_verified", "entity", "schema", "data_dir", "count_target"],
      "properties": {
        "spec":          { "const": "game-design.md" },
        "spec_version":  { "$ref": "#/$defs/SemVer" },
        "file_type":     { "const": "content-schema" },
        "status":        { "$ref": "#/$defs/Status" },
        "last_verified": { "$ref": "#/$defs/ISODate" },
        "entity":        { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "schema":        { "type": "object" },
        "data_dir":      { "type": "string" },
        "count_target":  { "type": "integer", "minimum": 0 },
        "balance_refs":  { "type": "array", "items": { "$ref": "#/$defs/TokenRef" } }
      },
      "additionalProperties": false
    },

    "ContentEntityFile": {
      "type": "object",
      "required": ["spec", "spec_version", "file_type", "id", "status", "implemented_in"],
      "properties": {
        "spec":          { "const": "game-design.md" },
        "spec_version":  { "$ref": "#/$defs/SemVer" },
        "file_type":     { "const": "content-entity" },
        "id":            { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "status":        { "$ref": "#/$defs/Status" },
        "implemented_in":{ "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": true
    }
  }
}
