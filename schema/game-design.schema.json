{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-design.md/schema/v0.1.1/game-design.schema.json",
  "title": "game-design.md frontmatter (v0.1.1)",
  "description": "Discriminated union over file_type. See docs/spec.md for normative semantics.",
  "type": "object",
  "required": ["spec", "spec_version", "file_type"],
  "properties": {
    "spec": { "const": "game-design.md" },
    "spec_version": { "$ref": "#/$defs/SemVer" },
    "file_type": {
      "enum": ["core", "subfile", "content-schema", "content-entity"]
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/CoreFile" },
    { "$ref": "#/$defs/Subfile" },
    { "$ref": "#/$defs/ContentSchemaFile" },
    { "$ref": "#/$defs/ContentEntityFile" }
  ],

  "$defs": {
    "SemVer": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },

    "ISODate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "Status": {
      "enum": ["draft", "prototyped", "implemented", "balanced", "shipped", "cut"]
    },

    "TokenRef": {
      "type": "string",
      "pattern": "^\\{[a-z_][a-z0-9_]*(?:\\.[a-z0-9_][a-z0-9_-]*){1,5}\\}$",
      "description": "{namespace.id...} with 2..6 dot-separated segments."
    },

    "ImplementedIn": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Workspace-relative path globs (fast-glob style)."
    },

    "ImplementationPointers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },

    "FilesMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^[^\\s].*\\.(md|yaml|yml)$"
      }
    },

    "MDAAesthetic": {
      "enum": ["sensation", "fantasy", "narrative", "challenge", "fellowship", "discovery", "expression", "submission"]
    },

    "Timescale": { "enum": ["moment", "session", "meta"] },
    "Scope":     { "enum": ["per_turn", "per_run", "permanent"] },
    "Visibility":{ "enum": ["hud", "inferred", "hidden"] },

    "PlayerExperienceGoals": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary":            { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" }, "minItems": 1 },
        "secondary":          { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" } },
        "explicit_non_goals": { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" } }
      },
      "additionalProperties": false
    },

    "Entity": {
      "type": "object",
      "required": ["type", "status"],
      "properties": {
        "type": { "enum": ["actor", "content_collection", "terrain", "currency", "system_object"] },
        "properties": { "type": "object" },
        "data_source": { "type": "string" },
        "schema_ref": { "$ref": "#/$defs/TokenRef" },
        "count_target": { "type": "integer", "minimum": 0 },
        "status": { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "allOf": [
        {
          "if":   { "properties": { "type": { "const": "content_collection" } } },
          "then": { "required": ["data_source"] },
          "else": { "required": ["properties", "implemented_in"] }
        }
      ],
      "additionalProperties": true
    },

    "Cost": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string" },
        {
          "type": "object",
          "required": ["resource", "amount"],
          "properties": {
            "resource": { "$ref": "#/$defs/TokenRef" },
            "amount":   { }
          }
        }
      ]
    },

    "Verb": {
      "type": "object",
      "required": ["actor", "cost", "target_schema", "effects", "status", "implemented_in"],
      "properties": {
        "actor":         { "type": "string", "minLength": 1 },
        "cost":          { "$ref": "#/$defs/Cost" },
        "target_schema": { "type": "object" },
        "effects":       { "type": "array", "minItems": 1 },
        "feel":          { "$ref": "#/$defs/TokenRef" },
        "status":        { "$ref": "#/$defs/Status" },
        "implemented_in":{ "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": true
    },

    "Resource": {
      "type": "object",
      "required": ["scope", "min", "max", "visibility", "status", "implemented_in"],
      "properties": {
        "scope":            { "$ref": "#/$defs/Scope" },
        "min":              { "type": "number" },
        "max":              { "type": "number" },
        "velocity_target":  { "$ref": "#/$defs/TokenRef" },
        "visibility":       { "$ref": "#/$defs/Visibility" },
        "status":           { "$ref": "#/$defs/Status" },
        "implemented_in":   { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "StateMachine": {
      "type": "object",
      "required": ["initial", "nodes", "transitions"],
      "properties": {
        "initial":     { "type": "string", "minLength": 1 },
        "nodes":       { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/StateNode" } },
        "transitions": { "type": "array", "items": { "$ref": "#/$defs/StateTransition" } }
      },
      "additionalProperties": false
    },

    "StateNode": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id":       { "type": "string", "minLength": 1, "pattern": "^[a-z0-9_]+$" },
        "terminal": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "StateTransition": {
      "type": "object",
      "required": ["from", "event", "to"],
      "properties": {
        "from":         { "type": "string", "minLength": 1 },
        "event":        { "type": "string", "minLength": 1 },
        "to":           { "type": "string", "minLength": 1 },
        "side_effects": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "Invariant": {
      "type": "object",
      "required": ["kind", "rule", "enforcement", "severity"],
      "properties": {
        "kind":        { "enum": ["numeric_domain", "architectural_pattern", "layer_boundary", "communication", "determinism"] },
        "rule":        { "type": "string", "minLength": 1 },
        "applies_to":  { "type": "array", "items": { "$ref": "#/$defs/TokenRef" } },
        "enforcement": { "enum": ["lint", "verify", "advisory"] },
        "severity":    { "enum": ["error", "warning", "info"] }
      },
      "additionalProperties": false
    },

    "VerifyTarget": {
      "type": "object",
      "required": ["axis"],
      "properties": {
        "axis":     { "enum": ["build_health", "behavioral_alignment", "presentation_usability"] },
        "target":   { "$ref": "#/$defs/TokenRef" },
        "seed":     { "type": "integer" },
        "sessions": { "type": "integer", "minimum": 1 },
        "expect":   { "type": "object" }
      },
      "additionalProperties": false
    },

    "VerifyResult": {
      "type": "object",
      "required": ["results", "summary"],
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["axis", "pass"],
            "properties": {
              "axis":     { "enum": ["build_health", "behavioral_alignment", "presentation_usability"] },
              "target":   { "type": "string" },
              "observed": { },
              "expected": { },
              "pass":     { "type": "boolean" },
              "notes":    { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "summary": {
          "type": "object",
          "required": ["runs", "passed", "failed", "skipped"],
          "properties": {
            "runs":    { "type": "integer", "minimum": 0 },
            "passed":  { "type": "integer", "minimum": 0 },
            "failed":  { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "Rule": {
      "type": "object",
      "required": ["given", "do", "outputs", "status", "implemented_in"],
      "properties": {
        "given": {
          "type": "object",
          "required": ["verb"],
          "properties": {
            "verb":  { "$ref": "#/$defs/TokenRef" },
            "state": { "$ref": "#/$defs/TokenRef" }
          },
          "additionalProperties": true
        },
        "do":             { "type": "array", "minItems": 1 },
        "outputs":        { "type": "array" },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "Loop": {
      "type": "object",
      "required": ["timescale", "duration", "sequence", "intended_dynamics", "intended_aesthetics", "status", "implemented_in"],
      "properties": {
        "timescale":           { "$ref": "#/$defs/Timescale" },
        "duration":            { "type": "string" },
        "sequence":            { "type": "array", "minItems": 1 },
        "intended_dynamics":   { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "intended_aesthetics": { "type": "array", "items": { "$ref": "#/$defs/MDAAesthetic" }, "minItems": 1 },
        "feel_priority":       { "enum": ["low", "medium", "high"] },
        "balance_targets":     { "type": "array", "items": { "$ref": "#/$defs/TokenRef" } },
        "status":              { "$ref": "#/$defs/Status" },
        "implemented_in":      { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "Distribution": {
      "type": "object",
      "required": ["type", "status", "implemented_in"],
      "properties": {
        "type":           { "enum": ["uniform", "weighted", "shuffle_bag", "gaussian", "pity_floor", "deterministic"] },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" },
        "seed":           { "type": "string" }
      },
      "allOf": [
        {
          "if":   { "properties": { "type": { "const": "uniform" } } },
          "then": { "required": ["range"], "properties": { "range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 } } }
        },
        {
          "if":   { "properties": { "type": { "const": "weighted" } } },
          "then": { "required": ["options"], "properties": { "options": { "type": "object", "minProperties": 2, "additionalProperties": { "type": "number", "minimum": 0 } } } }
        },
        {
          "if":   { "properties": { "type": { "const": "shuffle_bag" } } },
          "then": { "required": ["of"], "properties": { "of": { "$ref": "#/$defs/TokenRef" }, "refill_when": { "enum": ["empty", "manual", "per_run"] } } }
        },
        {
          "if":   { "properties": { "type": { "const": "gaussian" } } },
          "then": { "required": ["mean", "stddev"], "properties": { "mean": { "type": "number" }, "stddev": { "type": "number", "exclusiveMinimum": 0 }, "clamp": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 } } }
        },
        {
          "if":   { "properties": { "type": { "const": "pity_floor" } } },
          "then": { "required": ["table", "weights"], "properties": { "table": { "type": "array" }, "weights": { "type": "array", "items": { "type": "number" } }, "pity": { "type": "object" } } }
        },
        {
          "if":   { "properties": { "type": { "const": "deterministic" } } },
          "then": { "required": ["sequence"], "properties": { "sequence": { "type": "array", "minItems": 1 } } }
        }
      ],
      "additionalProperties": true
    },

    "Feel": {
      "type": "object",
      "required": ["input", "response", "context", "polish", "metaphor", "rules", "status", "implemented_in"],
      "properties": {
        "input":          { "type": "string" },
        "response":       { "type": "string" },
        "context":        { "type": "string" },
        "polish":         { "type": "string" },
        "metaphor":       { "type": "string" },
        "rules":          { "type": "string" },
        "status":         { "$ref": "#/$defs/Status" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": false
    },

    "BalanceTarget": {
      "type": "object",
      "required": ["target", "tolerance", "measure", "status"],
      "properties": {
        "target":    { },
        "tolerance": { "type": "array", "minItems": 2, "maxItems": 2 },
        "measure":   { "type": "string" },
        "status":    { "$ref": "#/$defs/Status" }
      },
      "additionalProperties": false
    },

    "CoreFile": {
      "type": "object",
      "required": [
        "spec", "spec_version", "file_type",
        "name", "short_pitch", "genre_tags",
        "status", "version", "last_updated",
        "target_platforms_neutral",
        "pillars", "non_goals", "player_experience_goals",
        "core_loop_ref", "files"
      ],
      "properties": {
        "spec":         { "const": "game-design.md" },
        "spec_version": { "$ref": "#/$defs/SemVer" },
        "file_type":    { "const": "core" },
        "name":         { "type": "string", "minLength": 1 },
        "short_pitch":  { "type": "string", "minLength": 1, "maxLength": 280 },
        "genre_tags":   { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "status":       { "$ref": "#/$defs/Status" },
        "version":      { "$ref": "#/$defs/SemVer" },
        "last_updated": { "$ref": "#/$defs/ISODate" },
        "target_platforms_neutral": {
          "type": "array",
          "items": { "enum": ["desktop", "handheld", "web", "console", "mobile", "mixed-reality"] },
          "minItems": 1
        },
        "pillars":      { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 5 },
        "non_goals":    { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "player_experience_goals": { "$ref": "#/$defs/PlayerExperienceGoals" },
        "core_loop_ref":{ "$ref": "#/$defs/TokenRef" },
        "files":        { "$ref": "#/$defs/FilesMap" },
        "implementation_pointers": { "$ref": "#/$defs/ImplementationPointers" },
        "verify_targets": { "type": "array", "items": { "$ref": "#/$defs/VerifyTarget" } },
        "adapters": {
          "type": "object",
          "additionalProperties": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
        }
      },
      "additionalProperties": false
    },

    "Subfile": {
      "type": "object",
      "required": ["spec", "spec_version", "file_type", "status", "last_verified"],
      "properties": {
        "spec":           { "const": "game-design.md" },
        "spec_version":   { "$ref": "#/$defs/SemVer" },
        "file_type":      { "const": "subfile" },
        "status":         { "$ref": "#/$defs/Status" },
        "last_verified":  { "$ref": "#/$defs/ISODate" },
        "implemented_in": { "$ref": "#/$defs/ImplementedIn" },
        "implementation_pointers": { "$ref": "#/$defs/ImplementationPointers" },

        "entities": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Entity" } },
        "verbs":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/Verb" } },
        "resources":{ "type": "object", "additionalProperties": { "$ref": "#/$defs/Resource" } },
        "states":   { "type": "object", "additionalProperties": { "$ref": "#/$defs/StateMachine" } },
        "rules":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/Rule" } },
        "loops":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/Loop" } },
        "distributions": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Distribution" } },
        "feel":     { "type": "object", "additionalProperties": { "$ref": "#/$defs/Feel" } },
        "balance_targets": { "type": "object", "additionalProperties": { "$ref": "#/$defs/BalanceTarget" } },
        "invariants":      { "type": "object", "additionalProperties": { "$ref": "#/$defs/Invariant" } },

        "verify_targets": { "type": "array", "items": { "$ref": "#/$defs/VerifyTarget" } },
        "adapters": {
          "type": "object",
          "additionalProperties": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
        },

        "pillars":     { "type": "array", "items": { "type": "string" } },
        "non_goals":   { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },

    "ContentSchemaFile": {
      "type": "object",
      "required": ["spec", "spec_version", "file_type", "status", "last_verified", "entity", "schema", "data_dir", "count_target"],
      "properties": {
        "spec":          { "const": "game-design.md" },
        "spec_version":  { "$ref": "#/$defs/SemVer" },
        "file_type":     { "const": "content-schema" },
        "status":        { "$ref": "#/$defs/Status" },
        "last_verified": { "$ref": "#/$defs/ISODate" },
        "entity":        { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "schema":        { "type": "object" },
        "data_dir":      { "type": "string" },
        "count_target":  { "type": "integer", "minimum": 0 },
        "balance_refs":  { "type": "array", "items": { "$ref": "#/$defs/TokenRef" } }
      },
      "additionalProperties": false
    },

    "ContentEntityFile": {
      "type": "object",
      "required": ["spec", "spec_version", "file_type", "id", "status", "implemented_in"],
      "properties": {
        "spec":          { "const": "game-design.md" },
        "spec_version":  { "$ref": "#/$defs/SemVer" },
        "file_type":     { "const": "content-entity" },
        "id":            { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "status":        { "$ref": "#/$defs/Status" },
        "implemented_in":{ "$ref": "#/$defs/ImplementedIn" }
      },
      "additionalProperties": true
    }
  }
}
